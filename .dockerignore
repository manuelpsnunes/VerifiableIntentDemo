# Keep the Docker build context small and deterministic.

# Node / Python build + cache artifacts
**/node_modules
**/dist
**/build
**/.vite
**/__pycache__
**/*.py[cod]
**/*.egg-info
**/.venv
.venv
**/.pytest_cache
**/.ruff_cache

# Runtime-generated key material (regenerated in-container on first run)
backend/keys/

# Env / secrets — never bake into the image
.env
.env.*

# VCS / IDE / OS
.git
.github
.gitignore
.idea
.vscode
**/.DS_Store
Thumbs.db

# Local-only helpers and docs not needed at runtime
chat-export.md
export-chat.ps1
