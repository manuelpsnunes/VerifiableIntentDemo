# Copy to .env and fill in. Never commit .env.

# --- LLM provider ---
# Anthropic Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...
# Model to use for the agent. claude-sonnet-4-5 is a good default.
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Payment network (mock vs. real Stripe) ---
# Default: "mock". Set to "stripe" once a real adapter is wired up (v2).
PAYMENT_NETWORK_MODE=mock
# Used only when PAYMENT_NETWORK_MODE=stripe (not implemented in v1).
STRIPE_SECRET_KEY=sk_test_...

# --- Server ---
HOST=127.0.0.1
PORT=8000
